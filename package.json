{
  "name": "al-zahra-smart-erp",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:analyze": "npm run build && npx vite-bundle-visualizer",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview",
    "clean": "chmod +x cleanup.sh && ./cleanup.sh",
    "scan:types": "tsx scripts/type-safety-scanner.ts",
    "type-check": "tsc --noEmit",
    "type-check:strict": "tsc --noEmit --strict",
    "test": "vitest",
    "test:ci": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "coverage": "vitest run --coverage",
    "quality:report": "tsx scripts/quality-report.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@google/genai": "^1.38.0",
    "@hookform/resolvers": "^5.2.2",
    "@supabase/supabase-js": "^2.93.2",
    "@tanstack/query-async-storage-persister": "^5.90.22",
    "@tanstack/query-sync-storage-persister": "^5.90.24",
    "@tanstack/react-query": "^5.90.20",
    "@tanstack/react-query-persist-client": "^5.90.20",
    "@tanstack/react-virtual": "^3.13.19",
    "clsx": "^2.1.1",
    "date-fns": "^3.3.1",
    "framer-motion": "^12.34.5",
    "html2canvas": "^1.4.1",
    "idb-keyval": "^6.2.1",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.563.0",
    "qrcode": "^1.5.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.51.0",
    "react-is": "^19.2.4",
    "react-router-dom": "^7.13.0",
    "react-to-print": "^3.2.0",
    "recharts": "^3.7.0",
    "stream-browserify": "^3.0.0",
    "tailwind-merge": "^3.4.0",
    "use-debounce": "^10.1.0",
    "vite-plugin-node-polyfills": "^0.25.0",
    "xlsx-js-style": "^1.2.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@playwright/test": "^1.42.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^14.2.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/node": "^20.11.24",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^1.3.0",
    "@vitest/ui": "^1.3.0",
    "autoprefixer": "^10.4.18",
    "eslint": "^9.9.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.9",
    "eslint-plugin-security": "^2.1.0",
    "globals": "^15.9.0",
    "husky": "^9.0.0",
    "jsdom": "^24.0.0",
    "lint-staged": "^15.2.0",
    "postcss": "^8.4.35",
    "prettier": "^3.2.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.2.2",
    "typescript-eslint": "^8.0.0",
    "vite": "^5.1.4",
    "vite-bundle-visualizer": "^1.0.0",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^1.3.0"
  }
}
