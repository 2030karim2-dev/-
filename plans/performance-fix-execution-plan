// AFTER:
// 1. Batch changes into a Set
let pendingChanges = new Set<string>();
let batchTimer: ReturnType<typeof setTimeout> | null = null;
const BATCH_DEBOUNCE_MS = 5000; // 5 seconds

const flushInvalidations = () => {
  if (pendingChanges.size === 0) return;
  
  // Group by preset to avoid duplicate invalidations
  const presetsToInvalidate = new Set<InvalidationPreset>();
  const keysToSetData = new Array<{ key: string; payload: any }>();
  
  pendingChanges.forEach(table => {
    const preset = TABLE_PRESET_MAP[table];
    if (preset) presetsToInvalidate.add(preset);
  });
  
  presetsToInvalidate.forEach(preset => {
    // Use precise invalidation instead of broad preset invalidation where possible
    const keys = INVALIDATION_PRESETS[preset];
    keys.forEach(key => {
      // Only invalidate if the query is currently active (has observers)
      queryClient.invalidateQueries({ queryKey: [key], type: 'active' });
    });
  });
  
  pendingChanges.clear();
  if (batchTimer) {
    clearTimeout(batchTimer);
    batchTimer = null;
  }
};

const channel = supabase.channel(channelId)
  .on('postgres_changes', 
    { event: '*', schema: 'public', filter: `company_id=eq.${companyId}` }, // 2. Filter by company
    (payload) => {
      pendingChanges.add(payload.table);
      
      if (!batchTimer) {
        batchTimer = setTimeout(flushInvalidations, BATCH_DEBOUNCE_MS);
      }
      
      // Immediate flush if critical table (e.g., invoices during POS)
      if (payload.table === 'invoices' || payload.table === 'products') {
        flushInvalidations();
      }
    }
  );
```

