# Husky pre-commit hook (updated)

echo "🔍 Running pre-commit checks..."

# Run lint-staged
npx lint-staged

# Type check
echo "📝 Type checking..."
npm run type-check:strict

# Check for console.log
echo "🔍 Checking for console.log statements..."
if grep -r "console\.log" --include="*.ts" --include="*.tsx" src/ 2>/dev/null | grep -v "logger.ts" | grep -v "index.tsx" | grep -v ".test." | grep -v "node_modules" | grep -v "scripts/"; then
  echo "❌ Found console.log statements. Please use the logger utility instead."
  exit 1
fi

echo "✅ Pre-commit checks passed!"
